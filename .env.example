# .env.example — AP Invoice & Contract Exception Agent (LedgerGate-Agent)
# Copy this file to .env and fill in the values marked as <required>.
# Never commit .env — it is git-ignored.
# All variables are loaded via pydantic-settings (app/config.py); do not
# read them ad hoc with os.getenv() anywhere in application code.

# ---------------------------------------------------------------------------
# LLM Gateway — OpenRouter
# ---------------------------------------------------------------------------

# Your OpenRouter API key.  Required — startup will fail if blank.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ordered fallback chain of OpenRouter model slugs (JSON array).
# Tried in sequence; each model gets one automatic retry on 429
# (Retry-After header respected) before the next model is attempted.
# The last model to return 429 raises LLMCallError.
# Verify current availability at https://openrouter.ai/models before changing.
OPENROUTER_FALLBACK_CHAIN=["openrouter/auto","google/gemma-3-27b-it:free","qwen/qwen3-235b-a22b:free","deepseek/deepseek-r1-0528:free"]

# Base URL for the OpenRouter API (OpenAI-compatible).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLAlchemy connection string.
# SQLite (default, zero-ops): sqlite:///./app.db
# Upgrade to Postgres by swapping this value — no other code changes needed.
DATABASE_URL=sqlite:///./app.db

# ---------------------------------------------------------------------------
# Business Logic — Thresholds & Rules
# ---------------------------------------------------------------------------

# Invoices at or above this amount (in the invoice currency) require an
# approval on file before they are eligible for STP.  Units: currency amount.
# See requirements.md for the approval-threshold rule definition.
APPROVAL_THRESHOLD_DEFAULT=10000

# Minimum annualized return required for an early-payment discount to be
# recommended.  Expressed as a decimal (0.10 = 10 %).
# See requirements.md FR-7 for the discount-recommendation formula.
DISCOUNT_HURDLE_RATE_DEFAULT=0.10

# Maximum allowable percentage variance between invoice and PO/contract
# values before a field is flagged as a mismatch.
# 0.0 means exact match required; 2.0 means ±2 % is acceptable.
MATCH_TOLERANCE_PERCENT=0.0

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Python logging level.  One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
